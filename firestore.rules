rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Pillar 0: Global Safety Net (Default Deny)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      // In this dev environment, we allow the mock IDs to function as authenticated
      return request.auth != null;
    }

    function isMock() {
      // Helper to identify if it's potentially a mock write (since we can't verify auth.uid for mocks)
      // We'll relax rules for specific mock operations
      return true; 
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Always allow reading profiles in this build
      allow read: if true;
      // Allow the app to initialize mock profiles
      allow write: if userId == 'mock-admin-id' || userId == 'mock-user-id' || (request.auth != null && request.auth.uid == userId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true; // Allow admin to seed categories
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if true; // Allow admin to seed protocols
    }

    match /user_results/{resultId} {
      allow read: if true;
      allow create, write: if true;
    }

    match /matrix_results/{id} {
      allow read: if true;
      allow create, write: if true;
    }

    match /enjoymentPlans/{id} {
      allow read: if true;
      allow create, write: if true;
    }

    match /enjoymentPlanDrafts/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /protocolResults/{id} {
      allow read: if true;
      allow create, write: if true;
    }
    
    // Support for connection testing
    match /test/connection {
      allow read: if true;
    }
  }
}
